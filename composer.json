{
    "name": "vusys/laravel-bitemporal",
    "description": "Effective-dated and bitemporal models for Laravel 11+.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://vusys.github.io/laravel-bitemporal/",
    "support": {
        "issues": "https://github.com/Vusys/laravel-bitemporal/issues",
        "source": "https://github.com/Vusys/laravel-bitemporal",
        "docs": "https://vusys.github.io/laravel-bitemporal/"
    },
    "require": {
        "php": "^8.4",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "infection/infection": "^0.29 || ^0.34",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": { "Vusys\\Bitemporal\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Vusys\\Bitemporal\\Tests\\": "tests/" }
    },
    "extra": {
        "laravel": {
            "providers": ["Vusys\\Bitemporal\\BitemporalServiceProvider"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "analyze": "@analyse",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "pint": "pint",
        "pint:check": "pint --test",
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "test:coverage-html": "XDEBUG_MODE=coverage phpunit --coverage-html=build/coverage",
        "infection": "infection",
        "infection:diff": "infection --git-diff-lines --git-diff-base=origin/master",
        "ci": ["@analyse", "@pint:check", "@rector:check", "@test"]
    }
}
